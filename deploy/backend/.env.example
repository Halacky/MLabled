# ── Backend connection settings ──
# Point these to the infrastructure server

# PostgreSQL (infrastructure server)
POSTGRES_HOST=192.168.1.100
POSTGRES_PORT=5432
POSTGRES_DB=mlabled
POSTGRES_USER=mlabled
POSTGRES_PASSWORD=mlabled

# Redis (infrastructure server)
REDIS_HOST=192.168.1.100
REDIS_PORT=6379

# MinIO (infrastructure server)
MINIO_HOST=192.168.1.100
MINIO_API_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_BUCKET=mlabled

# MinIO console URL (as seen from user's browser, for frontend links)
MINIO_CONSOLE_URL=http://192.168.1.100:9001

# Backend
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@mlabled.local
ADMIN_PASSWORD=admin
CORS_ORIGINS=["http://localhost:3000","http://192.168.1.200:3000"]

# Qwen adapter port
QWEN_ADAPTER_PORT=8501
