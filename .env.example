# ── MLabled — External Infrastructure ──

# PostgreSQL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@db-host:5432/mlabled

# Redis
REDIS_URL=redis://:password@redis-host:6379/0

# MinIO / S3
S3_ENDPOINT=http://minio-host:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mlabled

# MinIO console URL (shown in UI for "Browse in MinIO" links, leave empty to disable)
MINIO_CONSOLE_URL=http://minio-host:9001

# ── App ──
SECRET_KEY=change-me-in-production
ADMIN_EMAIL=admin@mlabled.local
ADMIN_PASSWORD=admin

# Ports (optional, defaults shown)
# FRONTEND_PORT=3000
# BACKEND_PORT=8010
