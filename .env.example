# MLabled Configuration

# Backend
SECRET_KEY=change-me-in-production-use-openssl-rand
DATABASE_URL=postgresql+asyncpg://mlabled:mlabled@postgres:5432/mlabled
REDIS_URL=redis://redis:6379/0

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mlabled

# Admin user (created on first start)
ADMIN_EMAIL=admin@mlabled.local
ADMIN_PASSWORD=admin

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
